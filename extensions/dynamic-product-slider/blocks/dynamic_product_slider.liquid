{%- liquid
  assign initial_source = ''

  if block.settings.enable_featured
    assign initial_source = 'featured'
  elsif block.settings.enable_random_products
    assign initial_source = 'random_products'
  elsif block.settings.enable_recently_purchased
    assign initial_source = 'recently_purchased'
  elsif block.settings.enable_monthly_best_sellers
    assign initial_source = 'monthly_best_sellers'
  endif

  if initial_source == ''
    assign initial_source = 'manual'
  endif
-%}

<div
  class="dynamic-product-slider"
  data-dynamic-product-slider
  data-initial-source="{{ initial_source | escape }}"
  data-limit="{{ block.settings.products_to_show }}"
  data-featured-collection="{% if block.settings.featured_collection != blank %}{{ block.settings.featured_collection.handle | escape }}{% endif %}"
  data-mobile-items="{{ block.settings.mobile_items }}"
  data-tablet-items="{{ block.settings.tablet_items }}"
  data-desktop-items="{{ block.settings.desktop_items }}"
  {{ block.shopify_attributes }}
>
  <div class="dynamic-product-slider__inner">
    {%- if block.settings.title != blank or block.settings.subtitle != blank -%}
      <header class="dynamic-product-slider__header">
        {%- if block.settings.title != blank -%}
          <h2 class="dynamic-product-slider__title">{{ block.settings.title | escape }}</h2>
        {%- endif -%}
        {%- if block.settings.subtitle != blank -%}
          <p class="dynamic-product-slider__subtitle">{{ block.settings.subtitle | escape }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="dynamic-product-slider__tabs" role="tablist" aria-label="Product sources" data-dynamic-product-slider-tabs>
      {%- if block.settings.enable_featured -%}
        <button
          type="button"
          class="dynamic-product-slider__tab{% if initial_source == 'featured' %} is-active{% endif %}"
          role="tab"
          aria-selected="{% if initial_source == 'featured' %}true{% else %}false{% endif %}"
          data-dynamic-product-slider-tab="featured"
        >
          Featured
        </button>
      {%- endif -%}

      {%- if block.settings.enable_random_products -%}
        <button
          type="button"
          class="dynamic-product-slider__tab{% if initial_source == 'random_products' %} is-active{% endif %}"
          role="tab"
          aria-selected="{% if initial_source == 'random_products' %}true{% else %}false{% endif %}"
          data-dynamic-product-slider-tab="random_products"
        >
          Random products
        </button>
      {%- endif -%}

      {%- if block.settings.enable_recently_purchased -%}
        <button
          type="button"
          class="dynamic-product-slider__tab{% if initial_source == 'recently_purchased' %} is-active{% endif %}"
          role="tab"
          aria-selected="{% if initial_source == 'recently_purchased' %}true{% else %}false{% endif %}"
          data-dynamic-product-slider-tab="recently_purchased"
        >
          Recently purchased
        </button>
      {%- endif -%}

      {%- if block.settings.enable_monthly_best_sellers -%}
        <button
          type="button"
          class="dynamic-product-slider__tab{% if initial_source == 'monthly_best_sellers' %} is-active{% endif %}"
          role="tab"
          aria-selected="{% if initial_source == 'monthly_best_sellers' %}true{% else %}false{% endif %}"
          data-dynamic-product-slider-tab="monthly_best_sellers"
        >
          Monthly best sellers
        </button>
      {%- endif -%}
    </div>

    <div class="dynamic-product-slider__viewport" data-dynamic-product-slider-viewport>
      <div
        class="dynamic-product-slider__track"
        data-dynamic-product-slider-track
      ></div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Dynamic product slider",
  "target": "section",
  "stylesheet": "dynamic-product-slider.css",
  "javascript": "dynamic-product-slider.js",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Featured products"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "header",
      "content": "Sources"
    },
    {
      "type": "checkbox",
      "id": "enable_featured",
      "label": "Enable featured collection",
      "default": false
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Featured collection"
    },
    {
      "type": "checkbox",
      "id": "enable_random_products",
      "label": "Enable random products",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_recently_purchased",
      "label": "Enable recently purchased products",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_monthly_best_sellers",
      "label": "Enable monthly best sellers",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 5,
      "max": 15,
      "step": 5,
      "default": 15
    },
    {
      "type": "range",
      "id": "mobile_items",
      "label": "Products per row on mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "tablet_items",
      "label": "Products per row on tablet",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "desktop_items",
      "label": "Products per row on desktop",
      "min": 3,
      "max": 5,
      "step": 1,
      "default": 5
    }
  ]
}
{% endschema %}
